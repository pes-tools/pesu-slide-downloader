{
  "manifest_version": 3,
  "name": "PESU Slide Downloader",
  "description": "Scan PESU Academy slide pages and save course materials as a ZIP or individual downloads.",
  "version": "1.0.0",
  "permissions": [
    "activeTab",
    "downloads",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://www.pesuacademy.com/*",
    "https://files.pesuacademy.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "PESU Slide Downloader",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.pesuacademy.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
